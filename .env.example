# Local development only — change ALL values for production
POSTGRES_PASSWORD=localdevpassword
DATABASE_URL=postgresql+asyncpg://terraducktel:localdevpassword@postgres:5432/terraducktel
CREDENTIAL_ENCRYPTION_KEY=local-dev-encryption-key-32bytes!!
JWT_SECRET_KEY=local-dev-jwt-secret-key-at-least-32-bytes-long!!
GITEA_RUNNER_REGISTRATION_TOKEN=placeholder-register-runner-in-forgejo-ui
DRIFT_DETECTOR_TOKEN=local-drift-token-replace-with-real-jwt
# Required for Terraform HTTP backend authentication; generate with `openssl rand -hex 32`
# Handed to every executor container — never give this the same value as
# TERRADUCKTEL_INTERNAL_TOKEN below, and never put it anywhere an executor
# (i.e. workspace-supplied Terraform/Helm code) could read it besides its own env.
TERRADUCKTEL_STATE_TOKEN=<set-to-32-byte-random-string>
# Required for the cross-tenant /api/v1/internal/* API (drift-detector,
# liveness-detector only); generate with `openssl rand -hex 32`. MUST be a
# different value than TERRADUCKTEL_STATE_TOKEN above and must never be
# passed to an executor container.
TERRADUCKTEL_INTERNAL_TOKEN=<set-to-a-different-32-byte-random-string>

# Optional: enable the "Import from Git → Local path" dev shortcut by mounting
# a host directory (where your terraform repos live) into the API container.
# Leave both BLANK in production — use a remote git URL + PAT (username/token)
# instead. The API rejects any path whose realpath escapes TERRADUCKTEL_LOCAL_REPOS_DIR.
# TERRADUCKTEL_LOCAL_REPOS_HOST_DIR=/home/you/github
# TERRADUCKTEL_LOCAL_REPOS_DIR=/mnt/local-repos

# S3 state backend (LocalStack in dev)
S3_USE_LOCALSTACK=true
S3_STATE_BUCKET=terraducktel-state

# SMTP notifications (optional)
# SMTP_HOST=smtp.example.com
# SMTP_PORT=587
# SMTP_FROM=noreply@example.com
# SMTP_TO=devops@example.com

# Session cookie (OIDC login handshake only) defaults to HTTPS-only. Only set
# this to false for a local, TLS-less setup where you're also testing OIDC
# against a real IdP (plain local/password auth never uses this cookie).
# SESSION_COOKIE_SECURE=false

# Executor hardening. `no-new-privileges` is on by default. A few host
# kernel/container-runtime combos reject execve of the executor entrypoint
# when it's set (the executor dies before any step runs). If — and only if —
# you hit that, set this to false. cap_drop=ALL + the non-root image user
# remain in effect either way.
# EXECUTOR_NO_NEW_PRIVS=false
